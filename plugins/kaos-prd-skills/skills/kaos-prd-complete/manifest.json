{
  "$schema": "../../../../manifest.schema.json",
  "name": "kaos-prd-complete",
  "type": "skill",
  "version": "1.0.0",
  "entry": "SKILL.md",
  "description": "Finalise an implemented PRD or close one that is no longer needed, and archive it.",
